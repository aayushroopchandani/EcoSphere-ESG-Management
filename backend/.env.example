APP_NAME=EcoSphere API
API_PREFIX=/api

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ecosphere

CORS_ORIGINS=http://localhost:3000

# Use your Clerk Frontend API URL with /.well-known/jwks.json appended.
# Example: https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# Usually the same Clerk Frontend API URL without /.well-known/jwks.json.
# Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=

# Comma separated origins that are allowed to mint frontend session tokens.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Governance RAG / AI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: use OpenRouter for chat generation while keeping OpenAI for embeddings.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GOVERNANCE_LLM_MODEL=google/gemini-2.5-flash-lite

# Qdrant: use QDRANT_URL for hosted Qdrant or QDRANT_PATH for local storage.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_PATH=qdrant_storage
GOVERNANCE_QDRANT_COLLECTION=governance_policy_chunks

# Optional Cloudinary PDF storage. If unset, PDFs are indexed only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
