APP_NAME=EcoSphere API
API_PREFIX=/api

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ecosphere

CORS_ORIGINS=http://localhost:3000

# Use your Clerk Frontend API URL with /.well-known/jwks.json appended.
# Example: https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# Usually the same Clerk Frontend API URL without /.well-known/jwks.json.
# Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=

# Comma separated origins that are allowed to mint frontend session tokens.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
